generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  school_admin
  teacher
  leader
  member
  expert
}

enum UserApprovalStatus {
  pending
  approved
}

enum ExpertReviewAssignmentStatus {
  pending
  completed
  locked
}

enum ExpertReviewMaterialKind {
  plan
  ppt
  video
}

enum ExpertReviewPackageStatus {
  configured
  cancelled
  archived
}

enum TaskStatus {
  todo
  doing
  review
  archived
  done
}

enum TaskPriority {
  high
  medium
  low
}

enum DocumentStatus {
  pending
  leader_approved
  approved
  leader_revision
  revision
}

enum DocumentCategory {
  plan
  ppt
  defense
  proof
}

enum NotificationEmailStatus {
  sent
  failed
  skipped
}

enum ReportEvaluationType {
  praise
  improve
  comment
}

enum ProjectReviewStageType {
  online_review
  roadshow
}

enum ProjectMaterialStatus {
  pending
  approved
  rejected
}

enum ReviewDisplaySessionStatus {
  waiting
  scoring
  revealed
  closed
}

enum ReviewDisplaySeatStatus {
  pending
  submitted
  voided
}

enum ReviewDisplayScreenPhase {
  draw
  presentation
  qa
  scoring
  reveal
  finished
}

model User {
  id                        String                      @id @default(cuid())
  name                      String
  username                  String                      @unique
  email                     String?                     @unique
  password                  String
  role                      Role
  approvalStatus            UserApprovalStatus          @default(approved)
  approvedAt                DateTime?
  approvedById              String?
  teamGroupId               String?
  emailVerifiedAt           DateTime?
  college                   String?
  className                 String?
  studentId                 String?
  employeeId                String?
  avatar                    String
  avatarImagePath           String?
  responsibility            String?
  createdAt                 DateTime                    @default(now())
  approvedBy                User?                       @relation("UserApprovals", fields: [approvedById], references: [id])
  approvedUsers             User[]                      @relation("UserApprovals")
  teamGroup                 TeamGroup?                  @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)
  tasksAssigned             Task[]                      @relation("TaskAssignee")
  taskAssignments           TaskAssignment[]            @relation("TaskAssignmentAssignee")
  tasksCreated              Task[]                      @relation("TaskCreator")
  tasksReviewed             Task[]                      @relation("TaskReviewer")
  taskAttachments           TaskAttachment[]            @relation("TaskAttachmentUploader")
  reports                   Report[]
  announcements             Announcement[]
  events                    Event[]                     @relation("EventCreator")
  expertFeedbacks           ExpertFeedback[]            @relation("ExpertFeedbackCreator")
  documents                 Document[]                  @relation("DocumentOwner")
  documentEdits             DocumentVersion[]           @relation("DocumentVersionUploader")
  notifications             Notification[]              @relation("NotificationRecipient")
  sentNotifications         Notification[]              @relation("NotificationSender")
  aiPermission              AiPermission?
  aiConversations           AiConversation[]
  pushDevices               PushDevice[]
  expertProfilesCreated     ExpertProfile[]             @relation("ExpertProfileCreator")
  expertProfile             ExpertProfile?              @relation("ExpertProfileAccount")
  expertReviewPackages      ExpertReviewPackage[]       @relation("ExpertReviewPackageCreator")
  expertAssignments         ExpertReviewAssignment[]    @relation("ExpertAssignmentUser")
  expertScores              ExpertReviewScore[]         @relation("ExpertScoreReviewer")
  reviewDisplaySessions     ReviewDisplaySession[]      @relation("ReviewDisplaySessionCreator")
  reviewDisplaySeats        ReviewDisplaySeat[]         @relation("ReviewDisplaySeatExpert")
  voidedReviewDisplaySeats  ReviewDisplaySeat[]         @relation("ReviewDisplaySeatVoider")
  trainingQuestions         TrainingQuestion[]          @relation("TrainingQuestionCreator")
  trainingSessions          TrainingSession[]           @relation("TrainingSessionCreator")
  passwordResetTokens       PasswordResetToken[]
  reportEvaluations         ReportEvaluation[]          @relation("ReportEvaluationCreator")
  projectReviewStages       ProjectReviewStage[]        @relation("ProjectReviewStageCreator")
  projectMaterialsSubmitted ProjectMaterialSubmission[] @relation("ProjectMaterialSubmitter")
  projectMaterialsApproved  ProjectMaterialSubmission[] @relation("ProjectMaterialApprover")
  projectMaterialsRejected  ProjectMaterialSubmission[] @relation("ProjectMaterialRejecter")
}

model EmailVerificationCode {
  id         String    @id @default(cuid())
  email      String
  purpose    String
  codeHash   String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([email, purpose, createdAt])
  @@index([expiresAt])
}

model AiPermission {
  id        String    @id @default(cuid())
  userId    String    @unique
  isEnabled Boolean   @default(false)
  maxCount  Int?
  usedCount Int       @default(0)
  resetAt   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isEnabled, updatedAt])
}

model AiConversation {
  id             String   @id @default(cuid())
  userId         String
  conversationId String   @unique
  title          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@index([userId, updatedAt])
}

model PushDevice {
  id         String   @id @default(cuid())
  userId     String
  platform   String
  pushToken  String
  deviceName String?
  appVersion String?
  isActive   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExpertProfile {
  id              String   @id @default(cuid())
  name            String
  phone           String?
  email           String?
  organization    String?
  title           String?
  specialtyTags   String   @default("[]")
  specialtyTracks String   @default("[]")
  specialtyText   String?
  notes           String?
  linkedUserId    String?  @unique
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  linkedUser      User?    @relation("ExpertProfileAccount", fields: [linkedUserId], references: [id], onDelete: SetNull)
  createdBy       User     @relation("ExpertProfileCreator", fields: [createdById], references: [id])

  @@index([name, organization])
  @@index([createdAt])
}

model TeamGroup {
  id                         String                      @id @default(cuid())
  name                       String                      @unique
  description                String?
  createdAt                  DateTime                    @default(now())
  members                    User[]
  tasks                      Task[]
  announcements              Announcement[]
  events                     Event[]
  expertFeedbacks            ExpertFeedback[]
  expertReviewPackages       ExpertReviewPackage[]
  trainingQuestions          TrainingQuestion[]
  trainingSessions           TrainingSession[]
  projectReviewStages        ProjectReviewStage[]
  projectMaterialSubmissions ProjectMaterialSubmission[]
  documents                  Document[]
}

model Task {
  id               String           @id @default(cuid())
  title            String
  status           TaskStatus
  priority         TaskPriority
  assigneeId       String?
  creatorId        String
  reviewerId       String?
  teamGroupId      String?
  sourceDocumentId String?
  dueDate          DateTime
  acceptedAt       DateTime?
  submittedAt      DateTime?
  archivedAt       DateTime?
  rejectedAt       DateTime?
  rejectionReason  String?
  completionNote   String?
  createdAt        DateTime         @default(now())
  assignee         User?            @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator          User             @relation("TaskCreator", fields: [creatorId], references: [id])
  reviewer         User?            @relation("TaskReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  teamGroup        TeamGroup?       @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)
  attachments      TaskAttachment[]
  assignments      TaskAssignment[]

  @@index([teamGroupId, status, dueDate])
  @@index([assigneeId, status])
  @@index([reviewerId, status])
  @@index([sourceDocumentId, status])
}

model TaskAssignment {
  id              String    @id @default(cuid())
  taskId          String
  assigneeId      String
  acceptedAt      DateTime?
  submittedAt     DateTime?
  archivedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  completionNote  String?
  createdAt       DateTime  @default(now())
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee        User      @relation("TaskAssignmentAssignee", fields: [assigneeId], references: [id])

  @@unique([taskId, assigneeId])
  @@index([assigneeId, submittedAt])
  @@index([taskId, submittedAt])
}

model TaskAttachment {
  id         String   @id @default(cuid())
  taskId     String
  uploaderId String
  fileName   String
  filePath   String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader   User     @relation("TaskAttachmentUploader", fields: [uploaderId], references: [id])

  @@index([taskId, uploadedAt])
}

model Report {
  id           String             @id @default(cuid())
  userId       String
  date         String
  summary      String
  nextPlan     String
  attachment   String?
  praiseCount  Int                @default(0)
  improveCount Int                @default(0)
  commentCount Int                @default(0)
  submittedAt  DateTime           @default(now())
  user         User               @relation(fields: [userId], references: [id])
  evaluations  ReportEvaluation[]

  @@unique([userId, date])
}

model ReportEvaluation {
  id            String               @id @default(cuid())
  reportId      String
  evaluatorId   String
  evaluatorRole Role
  type          ReportEvaluationType
  content       String?
  isRead        Boolean              @default(false)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  revokedAt     DateTime?
  report        Report               @relation(fields: [reportId], references: [id], onDelete: Cascade)
  evaluator     User                 @relation("ReportEvaluationCreator", fields: [evaluatorId], references: [id])

  @@index([reportId])
  @@index([evaluatorId])
  @@index([reportId, isRead])
}

model Announcement {
  id          String     @id @default(cuid())
  title       String
  detail      String
  authorId    String
  teamGroupId String?
  createdAt   DateTime   @default(now())
  author      User       @relation(fields: [authorId], references: [id])
  teamGroup   TeamGroup? @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)

  @@index([teamGroupId, createdAt])
}

model Event {
  id          String     @id @default(cuid())
  title       String
  dateTime    DateTime
  type        String
  description String
  creatorId   String?
  teamGroupId String?
  createdAt   DateTime   @default(now())
  creator     User?      @relation("EventCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  teamGroup   TeamGroup? @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)

  @@index([teamGroupId, dateTime])
}

model ExpertFeedback {
  id              String             @id @default(cuid())
  date            String
  expert          String
  topic           String
  format          String
  summary         String
  nextAction      String
  attachments     String
  createdById     String?
  teamGroupId     String?
  createdAt       DateTime           @default(now())
  createdBy       User?              @relation("ExpertFeedbackCreator", fields: [createdById], references: [id], onDelete: SetNull)
  teamGroup       TeamGroup?         @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)
  attachmentFiles ExpertAttachment[]

  @@index([teamGroupId, date, createdAt])
}

model ExpertAttachment {
  id         String         @id @default(cuid())
  feedbackId String
  fileName   String
  filePath   String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime       @default(now())
  feedback   ExpertFeedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

model Document {
  id             String            @id @default(cuid())
  name           String
  category       DocumentCategory
  ownerId        String
  teamGroupId    String?
  status         DocumentStatus
  comment        String?
  currentVersion String
  createdAt      DateTime          @default(now())
  owner          User              @relation("DocumentOwner", fields: [ownerId], references: [id])
  teamGroup      TeamGroup?        @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)
  versions       DocumentVersion[]

  @@index([teamGroupId])
}

model DocumentVersion {
  id         String   @id @default(cuid())
  documentId String
  version    String
  uploadedAt DateTime @default(now())
  uploaderId String
  note       String
  fileName   String
  filePath   String
  fileSize   Int
  mimeType   String
  document   Document @relation(fields: [documentId], references: [id])
  uploader   User     @relation("DocumentVersionUploader", fields: [uploaderId], references: [id])
}

model Notification {
  id          String                   @id @default(cuid())
  userId      String
  senderId    String?
  documentId  String?
  title       String
  detail      String
  type        String
  targetTab   String?
  relatedId   String?
  isRead      Boolean                  @default(false)
  readAt      DateTime?
  emailStatus NotificationEmailStatus?
  emailError  String?
  emailSentAt DateTime?
  createdAt   DateTime                 @default(now())
  user        User                     @relation("NotificationRecipient", fields: [userId], references: [id])
  sender      User?                    @relation("NotificationSender", fields: [senderId], references: [id])

  @@index([userId, isRead, createdAt])
  @@index([senderId, type, createdAt])
}

model EmailReminderSetting {
  id                        String   @id
  taskAssignmentEnabled     Boolean  @default(true)
  taskReviewEnabled         Boolean  @default(true)
  announcementEnabled       Boolean  @default(true)
  directReminderEnabled     Boolean  @default(true)
  documentReviewEnabled     Boolean  @default(true)
  reportSubmitEnabled       Boolean  @default(true)
  dailyReportMissingEnabled Boolean  @default(true)
  dailyReportHour           Int      @default(20)
  updatedAt                 DateTime @updatedAt
}

model ProjectReviewStage {
  id          String                      @id @default(cuid())
  name        String
  type        ProjectReviewStageType
  description String?
  isOpen      Boolean                     @default(false)
  startAt     DateTime?
  deadline    DateTime?
  createdById String
  teamGroupId String?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  creator     User                        @relation("ProjectReviewStageCreator", fields: [createdById], references: [id])
  teamGroup   TeamGroup?                  @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)
  submissions ProjectMaterialSubmission[]
  packages    ExpertReviewPackage[]

  @@index([isOpen, deadline])
  @@index([teamGroupId, createdAt])
}

model ProjectMaterialSubmission {
  id            String                @id @default(cuid())
  stageId       String
  teamGroupId   String
  submittedById String
  title         String
  fileName      String
  filePath      String
  fileSize      Int
  mimeType      String
  status        ProjectMaterialStatus @default(pending)
  approvedById  String?
  approvedAt    DateTime?
  rejectedById  String?
  rejectedAt    DateTime?
  rejectReason  String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  stage         ProjectReviewStage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  teamGroup     TeamGroup             @relation(fields: [teamGroupId], references: [id], onDelete: Cascade)
  submitter     User                  @relation("ProjectMaterialSubmitter", fields: [submittedById], references: [id])
  approver      User?                 @relation("ProjectMaterialApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  rejecter      User?                 @relation("ProjectMaterialRejecter", fields: [rejectedById], references: [id], onDelete: SetNull)

  @@index([stageId, status, createdAt])
  @@index([teamGroupId, stageId, status])
  @@index([submittedById, createdAt])
}

model ExpertReviewPackage {
  id                   String                      @id @default(cuid())
  targetName           String
  roundLabel           String?
  overview             String?
  status               ExpertReviewPackageStatus   @default(configured)
  startAt              DateTime?
  deadline             DateTime?
  dropHighestCount     Int                         @default(1)
  dropLowestCount      Int                         @default(1)
  createdById          String
  teamGroupId          String?
  projectReviewStageId String?
  createdAt            DateTime                    @default(now())
  creator              User                        @relation("ExpertReviewPackageCreator", fields: [createdById], references: [id])
  teamGroup            TeamGroup?                  @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)
  projectReviewStage   ProjectReviewStage?         @relation(fields: [projectReviewStageId], references: [id], onDelete: SetNull)
  materials            ExpertReviewMaterial[]
  assignments          ExpertReviewAssignment[]
  displaySessions      ReviewDisplaySession[]
  projectOrders        ReviewDisplayProjectOrder[]

  @@index([teamGroupId, createdAt])
  @@index([projectReviewStageId, createdAt])
  @@index([projectReviewStageId, teamGroupId, status])
  @@index([status, createdAt])
}

model ExpertReviewAssignment {
  id            String                       @id @default(cuid())
  packageId     String
  expertUserId  String
  status        ExpertReviewAssignmentStatus @default(pending)
  createdAt     DateTime                     @default(now())
  reviewPackage ExpertReviewPackage          @relation(fields: [packageId], references: [id], onDelete: Cascade)
  expertUser    User                         @relation("ExpertAssignmentUser", fields: [expertUserId], references: [id])
  score         ExpertReviewScore?
  displaySeats  ReviewDisplaySeat[]

  @@unique([packageId, expertUserId])
  @@index([expertUserId, status, createdAt])
}

model ExpertReviewMaterial {
  id            String                   @id @default(cuid())
  packageId     String
  kind          ExpertReviewMaterialKind
  name          String
  fileName      String
  filePath      String
  fileSize      Int
  mimeType      String
  uploadedAt    DateTime                 @default(now())
  reviewPackage ExpertReviewPackage      @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, kind])
  @@index([packageId, kind])
}

model ExpertReviewScore {
  id                  String                 @id @default(cuid())
  assignmentId        String                 @unique
  reviewerId          String
  scorePersonalGrowth Int
  scoreInnovation     Int
  scoreIndustry       Int
  scoreTeamwork       Int
  totalScore          Int
  commentTotal        String
  submittedAt         DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  lockedAt            DateTime?
  assignment          ExpertReviewAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  reviewer            User                   @relation("ExpertScoreReviewer", fields: [reviewerId], references: [id])
}

model ReviewDisplaySession {
  id                  String                      @id @default(cuid())
  packageId           String
  tokenHash           String                      @unique
  startsAt            DateTime?
  tokenExpiresAt      DateTime
  countdownSeconds    Int                         @default(60)
  dropHighestCount    Int                         @default(1)
  dropLowestCount     Int                         @default(1)
  status              ReviewDisplaySessionStatus  @default(waiting)
  startedAt           DateTime?
  endedAt             DateTime?
  screenPhase         ReviewDisplayScreenPhase    @default(draw)
  currentPackageId    String?
  presentationSeconds Int                         @default(480)
  qaSeconds           Int                         @default(420)
  scoringSeconds      Int                         @default(60)
  phaseStartedAt      DateTime?
  revealStartedAt     DateTime?
  createdById         String
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  reviewPackage       ExpertReviewPackage         @relation(fields: [packageId], references: [id], onDelete: Cascade)
  creator             User                        @relation("ReviewDisplaySessionCreator", fields: [createdById], references: [id])
  seats               ReviewDisplaySeat[]
  projectOrders       ReviewDisplayProjectOrder[]

  @@index([packageId, status])
  @@index([tokenExpiresAt])
}

model ReviewDisplaySeat {
  id           String                  @id @default(cuid())
  sessionId    String
  assignmentId String
  expertUserId String
  seatNo       Int
  displayName  String
  status       ReviewDisplaySeatStatus @default(pending)
  voidedAt     DateTime?
  voidedById   String?
  voidReason   String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  session      ReviewDisplaySession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  assignment   ExpertReviewAssignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  expertUser   User                    @relation("ReviewDisplaySeatExpert", fields: [expertUserId], references: [id])
  voidedBy     User?                   @relation("ReviewDisplaySeatVoider", fields: [voidedById], references: [id], onDelete: SetNull)

  @@unique([sessionId, assignmentId])
  @@unique([sessionId, seatNo])
  @@index([expertUserId, status])
}

model ReviewDisplayProjectOrder {
  id                 String               @id @default(cuid())
  sessionId          String
  packageId          String
  orderIndex         Int
  groupName          String?
  groupIndex         Int                  @default(0)
  groupSlotIndex     Int                  @default(0)
  revealedAt         DateTime?
  finalScoreCents    Int?
  finalScoreText     String?
  effectiveSeatCount Int?
  submittedSeatCount Int?
  droppedSeatNos     String?
  dropHighestCount   Int?
  dropLowestCount    Int?
  scoreLockedAt      DateTime?
  createdAt          DateTime             @default(now())
  session            ReviewDisplaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reviewPackage      ExpertReviewPackage  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([sessionId, packageId])
  @@index([sessionId, orderIndex])
}

model TrainingQuestion {
  id           String     @id @default(cuid())
  category     String
  question     String
  answerPoints String
  createdById  String
  teamGroupId  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    User       @relation("TrainingQuestionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  teamGroup    TeamGroup? @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)

  @@index([category, createdAt])
  @@index([createdById, createdAt])
  @@index([teamGroupId, createdAt])
}

model TrainingSession {
  id              String     @id @default(cuid())
  title           String?
  durationSeconds Int
  overtimeSeconds Int        @default(0)
  qaTotal         Int        @default(0)
  qaHit           Int        @default(0)
  notes           String?
  createdById     String
  teamGroupId     String?
  createdAt       DateTime   @default(now())
  createdBy       User       @relation("TrainingSessionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  teamGroup       TeamGroup? @relation(fields: [teamGroupId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([createdById, createdAt])
  @@index([teamGroupId, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
